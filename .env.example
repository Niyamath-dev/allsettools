# Google Sheets Integration Webhook URL configurations (Optional)
# If omitted here, you can also configure them directly in the browser via the Admin Dashboard.
# Deployed from Google Sheets Extensions -> Apps Script as Web App (Anyone)
GOOGLE_SHEETS_WEBHOOK_URL=
